[1.922, "o", "usage: cast-render  [-h] [--title TITLE] [--gif-only] [--mp4-only] [--render-fps N] [--gif-fps N] [--mp4-fps N] [--hold SEC] [--keep-frames] [--version] [-v {0,1,2,3}] [--traceback] cast_file output_base\r\n\r\nConvert an asciinema .cast file to GIF and/or MP4\r\n\r\npositional arguments:\r\n  cast_file             Path to the .cast input file\r\n  output_base           Output base path, e.g. assets/demo â†’ demo.gif + demo.mp4\r\n\r\noptions:\r\n  -h, --help            show this help message and exit\r\n  --title TITLE         Window title bar text (default: empty)\r\n  --gif-only            Produce GIF only (skip MP4)\r\n  --mp4-only            Produce MP4 only (skip GIF)\r\n  --render-fps N        Internal render FPS used for PNG frames (default: 30)\r\n  --gif-fps N           GIF output FPS (default: 10)\r\n  --mp4-fps N           MP4 output FPS (default: 30)\r\n  --hold SEC            Seconds to hold the last frame (default: 3.0)\r\n  --keep-frames         Keep temporary PNG frames after encoding (useful for debugging)\r\n  --version      "]
[0.000, "o", "       Show program's version number and exit.\r\n  -v, --verbosity {0,1,2,3}\r\n                        Verbosity level; 0=minimal, 1=normal, 2=verbose, 3=very verbose.\r\n  --traceback           Raise on CommandError instead of logging cleanly.\r\n"]
